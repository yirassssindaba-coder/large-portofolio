  ['/portfolio', 'portfolio.html'],
  ['/portfolio.html', 'portfolio.html'],
  ['/game', 'game.html'],
  ['/game.html', 'game.html'],
  ['/manager', 'manager.html'],
  ['/manager.html', 'manager.html'],
  ['/posts', 'posts.html'],
